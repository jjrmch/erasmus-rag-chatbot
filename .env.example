# ─── PostgreSQL ───────────────────────────────────────────────
POSTGRES_USER=root
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=n8n

# ─── pgweb ────────────────────────────────────────────────────
PGWEB_USER=CHANGE_ME
PGWEB_PASSWORD=CHANGE_ME
PGWEB_AUTH_USER=CHANGE_ME
PGWEB_AUTH_PASS=CHANGE_ME
DATABASE_URL=postgres://root:CHANGE_ME@postgres:5432/n8n?sslmode=disable

# ─── n8n core ─────────────────────────────────────────────────
DB_TYPE=postgresdb
DB_POSTGRESDB_HOST=postgres
DB_POSTGRESDB_USER=root
DB_POSTGRESDB_PASSWORD=CHANGE_ME
N8N_ENCRYPTION_KEY=CHANGE_ME_min32chars
N8N_USER_MANAGEMENT_JWT_SECRET=CHANGE_ME_min32chars
N8N_DEFAULT_BINARY_DATA_MODE=filesystem
N8N_SECURE_COOKIE=false
N8N_DIAGNOSTICS_ENABLED=false
N8N_PERSONALIZATION_ENABLED=false

# ─── n8n URLs ─────────────────────────────────────────────────
WEBHOOK_URL=http://localhost:5678
N8N_EDITOR_BASE_URL=http://localhost:5678
N8N_PROTOCOL=http

# ─── n8n comportamiento ───────────────────────────────────────
N8N_CONCURRENCY_PRODUCTION_LIMIT=10
N8N_COMMUNITY_PACKAGES_ALLOW_TOOL_USAGE=true
NODES_EXCLUDE=[]
N8N_BLOCK_ENV_ACCESS_IN_NODE=false
N8N_RESTRICT_FILE_ACCESS_TO=/demo-data;/data/shared;/data/correos_descartados;/data/procesar_sin_comprobar

# ─── n8n timeouts HTTP ────────────────────────────────────────
N8N_HTTP_REQUEST_TIMEOUT=0
N8N_HTTP_HEADERS_TIMEOUT=120000
N8N_HTTP_KEEPALIVE_TIMEOUT=65000

# ─── Timeouts fetch/undici ────────────────────────────────────
FETCH_HEADERS_TIMEOUT=3000000
FETCH_BODY_TIMEOUT=30000000
FETCH_CONNECT_TIMEOUT=600000
FETCH_KEEPALIVE_TIMEOUT=65000

# ─── Ollama ───────────────────────────────────────────────────
OLLAMA_HOST=ollama:11434

# ─── Qdrant ───────────────────────────────────────────────────
QDRANT_API_KEY=CHANGE_ME
QDRANT__SERVICE__API_KEY=CHANGE_ME

# ─── Adminer ──────────────────────────────────────────────────
ADMINER_DEFAULT_SERVER=postgres
ADMINER_DESIGN=nette